{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "api:generate-openapi": "php artisan api:generate-openapi",
        "api:generate": "npm run api:generate-openapi && openapi-ts",
        "api:generate-watch": "nodemon --watch src/app --watch src/routes --ext php --exec 'npm run api:generate' --delay 1000",
        "type-check": "tsc --noEmit"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.5.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "nodemon": "^3.1.14",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@hey-api/openapi-ts": "^0.97.3",
        "@inertiajs/react": "^3.3.0",
        "@inertiajs/vue3": "^3.3.0",
        "@tanstack/react-query": "^5.100.14",
        "@tanstack/react-table": "^8.21.3",
        "@vitejs/plugin-react": "^6.0.2",
        "axios": "^1.16.1",
        "framer-motion": "^12.40.0",
        "lucide-react": "^1.17.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-hook-form": "^7.76.1",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    }
}
